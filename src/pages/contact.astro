---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';
import ContactForm from '../components/ContactForm.astro';

const faqs = [
  { q: 'What areas do you serve?', a: 'We serve Orange County, CA and surrounding cities.' },
  { q: 'Are you licensed and insured?', a: 'Yes. CA Lic. #1127416. Fully licensed, bonded, and insured on every project.' },
  { q: 'How long have you been in business?', a: "We were founded in 2024 by a team that has been building in Orange County for years. We're new to the brand, not new to the trade." },
  { q: 'Do you handle permits?', a: "Yes. We pull all permits. You never have to deal with the city yourself — that's our job." },
  { q: 'Do you handle HOA approvals?', a: 'Yes. If your project requires HOA approval, we manage the submission process and attend review meetings when needed.' },
  { q: 'Can I live in my house during a remodel?', a: "It depends on the scope. For kitchen and bathroom remodels, most clients stay home. For whole-home renovations, we'll give you an honest answer about what to expect before we start." },
  { q: 'How do you handle selections and allowances?', a: 'We establish your allowances upfront in your contract. You make selections with our guidance, and we track every choice against your budget in real time — no surprises at the end.' },
  { q: 'How do change orders work?', a: 'If the scope changes, we issue a written change order with the cost and timeline impact before any additional work begins. You approve it in writing. Nothing happens without your sign-off.' },
  { q: 'What is your warranty?', a: "We provide a 1-year workmanship warranty on all labor. Manufacturer warranties on materials pass through directly to you. We'll walk you through what's covered at final walkthrough." },
  { q: 'Can I get a price without drawings?', a: 'Yes. We can give you a realistic budget range on the first call based on your scope and square footage. Full pricing requires permit-ready drawings.' },
  { q: 'Can you give me a ballpark before moving into full estimating?', a: "Absolutely. A 10-minute call is usually enough to give you a ballpark range. We won't waste your time or ours." },
  { q: 'How long does an ADU take to build?', a: 'Typically 4–6 months from permit approval to move-in, depending on size and complexity.' },
  { q: 'Do you do design-build or work from existing plans?', a: "Both. We can coordinate design for you, or work directly from your architect's plans. Already have drawings? Email them to futureconstructionteam@gmail.com." },
  { q: 'What is your typical project minimum?', a: 'We take on projects starting at $50K. Most of our projects range from $100K–$1M+.' },
  { q: 'How do you handle communication during a project?', a: 'You get daily photo logs, a dedicated PM as your point of contact, and weekly check-in calls. No chasing us down.' },
  { q: 'Can I see past projects similar to mine?', a: "Yes. Reach out and we'll share relevant examples from our portfolio." },
  { q: 'What happens after I fill out this form?', a: 'We review your submission and respond within 1 business day to schedule a free consultation call.' },
];
---
<BaseLayout
  title="Start My Project"
  description="Tell us about your project. We respond within 1 business day."
>

  <!-- HEADLINE + FORM (Top section) -->
  <section class="bg-fcd-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 py-16 grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- LEFT: copy and contact info -->
      <div class="lg:col-span-5">
        <SectionLabel>Start My Project</SectionLabel>
        <h1 class="font-heading font-bold tracking-tight text-fcd-navy text-4xl lg:text-5xl leading-[1.05] mb-6">
          Let's Talk About Your Project.
        </h1>

        <h2 class="font-heading text-2xl text-fcd-navy font-semibold mb-3">What Happens Next.</h2>
        <p class="text-base text-fcd-navy/80 leading-relaxed mb-5">
          Tell us a little about your project. Within 1 business day, you'll hear directly from our team to schedule a free consultation call.
        </p>

        <ul class="space-y-3">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-fcd-navy/90">Free ballpark range — no obligation</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-fcd-navy/90">Real answers about scope and timeline</span>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-base text-fcd-navy/90">Honest read on whether we're a fit</span>
          </li>
        </ul>
      </div>

      <!-- RIGHT: form -->
      <div class="lg:col-span-7">
        <div class="bg-fcd-card border border-fcd-border rounded-lg p-6 sm:p-8 lg:p-10">
          <ContactForm />
        </div>
      </div>

    </div>
  </section>

  <!-- VISIT & CONTACT US -->
  <section class="bg-fcd-cream py-24 lg:py-32 border-t border-fcd-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">

      <!-- Four compact horizontal contact cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">

        <!-- Card 1: Call -->
        <a href="tel:+17149279777" class="flex items-center gap-3 hover:opacity-90 transition-opacity"
           style="background:#f7f4ef; border:1px solid #e8e3da; border-radius:12px; padding:14px 16px;">
          <div class="flex items-center justify-center flex-shrink-0" style="width:36px; height:36px; background:#dab76b; border-radius:8px;">
            <svg class="w-5 h-5" fill="none" stroke="#00253e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.95l-1.27 1.27a16 16 0 006.586 6.586l1.27-1.27a2 2 0 011.95-.45l2.8.7A2 2 0 0121 18.72V21a2 2 0 01-2 2A18 18 0 013 5z"/></svg>
          </div>
          <div class="min-w-0">
            <p style="color:#00253e; font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:0.08em;">Call Us</p>
            <p class="font-heading font-semibold" style="color:#00253e; font-size:16px; margin-top:2px;">(714) 927-9777</p>
          </div>
        </a>

        <!-- Card 2: Text -->
        <a href="sms:+17149279777" class="flex items-center gap-3 hover:opacity-90 transition-opacity"
           style="background:#f7f4ef; border:1px solid #e8e3da; border-radius:12px; padding:14px 16px;">
          <div class="flex items-center justify-center flex-shrink-0" style="width:36px; height:36px; background:#dab76b; border-radius:8px;">
            <svg class="w-5 h-5" fill="none" stroke="#00253e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.86 9.86 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <p style="color:#00253e; font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:0.08em;">Text Us</p>
        </a>

        <!-- Card 3: Email -->
        <a href="mailto:futureconstructionteam@gmail.com" class="flex items-center gap-3 hover:opacity-90 transition-opacity"
           style="background:#f7f4ef; border:1px solid #e8e3da; border-radius:12px; padding:14px 16px;">
          <div class="flex items-center justify-center flex-shrink-0" style="width:36px; height:36px; background:#dab76b; border-radius:8px;">
            <svg class="w-5 h-5" fill="none" stroke="#00253e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          </div>
          <p style="color:#00253e; font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:0.08em;">Email</p>
        </a>

        <!-- Card 4: Office (opens directions) -->
        <a href="https://www.google.com/maps/dir/?api=1&destination=12122+Brookhurst+St%2C+Garden+Grove%2C+CA+92840" target="_blank" rel="noopener" class="flex items-center gap-3 hover:opacity-90 transition-opacity"
           style="background:#f7f4ef; border:1px solid #e8e3da; border-radius:12px; padding:14px 16px;">
          <div class="flex items-center justify-center flex-shrink-0" style="width:36px; height:36px; background:#dab76b; border-radius:8px;">
            <svg class="w-5 h-5" fill="none" stroke="#00253e" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <p style="color:#00253e; font-size:11px; font-weight:500; text-transform:uppercase; letter-spacing:0.08em;">Our Office</p>
        </a>

      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-fcd-dark py-24 lg:py-32">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <div class="mb-16">
        <SectionLabel>FAQ</SectionLabel>
        <h2 class="font-heading text-4xl text-fcd-navy font-semibold">Questions, Answered.</h2>
      </div>

      <div class="space-y-3">
        {faqs.map((f, i) => (
          <details class="group bg-fcd-card border border-fcd-border rounded-lg overflow-hidden hover:border-fcd-gold/50 transition-colors">
            <summary class="flex items-center justify-between gap-4 p-6 cursor-pointer list-none">
              <h3 class="font-heading text-lg text-fcd-navy font-semibold">{f.q}</h3>
              <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 transition-transform group-open:rotate-45" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/></svg>
            </summary>
            <div class="px-6 pb-6 text-fcd-muted leading-relaxed">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
