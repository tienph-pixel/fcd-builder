---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';

const faqs = [
  { q: "How much does a kitchen remodel cost in Orange County?", a: "Kitchen remodels in Orange County range widely: a mid-range update (new cabinets, countertops, appliances) runs $50,000–$100,000. A full gut remodel with structural changes, custom cabinetry, and high-end finishes runs $100,000–$200,000+. We give you a fixed price before any work starts." },
  { q: "How long does a kitchen remodel take?", a: "Most kitchen remodels take 6–12 weeks once active construction begins. Lead times on cabinets and appliances can add 4–8 weeks to the planning phase. We build the full timeline into your proposal so you know exactly when you'll have your kitchen back." },
  { q: "Can I live at home during a kitchen remodel?", a: "Most clients do. We minimize disruption by protecting adjacent rooms, cleaning up daily, and sequencing trades to avoid extended shutdowns. We will give you an honest assessment of what to expect before we start." },
  { q: "Do you handle plumbing and electrical, or do I hire those separately?", a: "We coordinate everything — plumbing, electrical, framing, tile, cabinets, countertops, appliances. You have one point of contact. You do not chase subs." },
  { q: "Do you pull permits for kitchen remodels?", a: "Yes, when permits are required. Any structural work, electrical panel changes, or plumbing relocations require permits in Orange County. We handle all of it — submittal, plan check, inspections." },
  { q: "What finishes and brands do you work with?", a: "We work with the brands and suppliers you choose, or we can guide you through selections. We have established relationships with cabinet suppliers, countertop fabricators, and tile distributors throughout Orange County." },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Kitchen Remodel Orange County",
  "description": "Licensed kitchen remodeling contractor in Orange County, CA. Full gut remodels, cabinet replacement, countertops, layout changes. CA Lic. #1127416.",
  "provider": { "@type": "LocalBusiness", "name": "Future Construction & Design INC", "url": "https://www.fcdteam.com", "telephone": "(714) 927-9777", "address": { "@type": "PostalAddress", "streetAddress": "12122 Brookhurst St", "addressLocality": "Garden Grove", "addressRegion": "CA", "postalCode": "92840", "addressCountry": "US" }, "license": "CA Lic. #1127416" },
  "serviceType": "Kitchen Remodeling",
  "areaServed": "Orange County, CA"
};
---
<BaseLayout
  title="Kitchen Remodel Orange County | Future Construction & Design"
  description="Licensed kitchen remodeling contractor in Orange County, CA. Full gut remodels, custom cabinets, countertops, layout changes. Fixed-price proposals. CA Lic. #1127416."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="relative flex items-center" style="min-height: 55vh;">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/projects/remodel-1.jpg" alt="Kitchen remodel Orange County" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,37,62,0.88) 50%, rgba(0,37,62,0.4));"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-20 w-full">
      <SectionLabel>Kitchen Remodeling · Orange County</SectionLabel>
      <h1 class="font-heading font-bold tracking-tight text-white text-4xl lg:text-6xl leading-[1.05] max-w-3xl mt-4">Kitchen Remodel Orange County</h1>
      <p class="mt-6 text-base lg:text-lg text-white/80 leading-relaxed max-w-2xl">Full kitchen remodels — cabinets, countertops, layout changes, plumbing, electrical, tile — all coordinated by one team. No chasing separate contractors. CA Lic. #1127416.</p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:bg-fcd-gold-lt transition-colors duration-200">Get Kitchen Quote &rarr;</a>
        <a href="tel:7149279777" class="inline-flex items-center justify-center gap-2 border border-white/40 text-white font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:border-fcd-gold hover:text-fcd-gold transition-colors duration-200">(714) 927-9777</a>
      </div>
      <div class="mt-8 flex flex-wrap gap-6 text-sm text-white/70">
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>All Trades Coordinated</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Fixed-Price Proposals</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Permits Handled</span>
      </div>
    </div>
  </section>

  <section class="bg-fcd-cream py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <SectionLabel>What's Included</SectionLabel>
        <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-8">One Team. Every Trade. Zero Chaos.</h2>
        <div class="space-y-4">
          {["Cabinet design, supply, and installation", "Countertop fabrication and installation", "Layout changes and wall removal where applicable", "Plumbing relocation — sink, dishwasher, refrigerator line", "Electrical — circuits, outlets, under-cabinet lighting", "Tile backsplash and flooring", "Appliance coordination and installation", "Permits when required — we handle all of it", "Daily cleanup. Respectful crew. No mess left behind."].map(item => (
            <div class="flex gap-3 items-start">
              <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-fcd-navy/80">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="space-y-4">
        <div class="rounded-lg overflow-hidden aspect-[16/9]"><img src="/images/projects/remodel-2.jpg" alt="Kitchen remodel Orange County" loading="lazy" class="w-full h-full object-cover" /></div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg overflow-hidden aspect-square"><img src="/images/projects/remodel-3.jpg" alt="Kitchen renovation Orange County" loading="lazy" class="w-full h-full object-cover" /></div>
          <div class="rounded-lg overflow-hidden aspect-square"><img src="/images/projects/remodel-4.jpg" alt="Kitchen remodel OC" loading="lazy" class="w-full h-full object-cover" /></div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-fcd-dark py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-3 gap-8">
      {[{ stat: "$50K–$200K+", label: "Typical Range", sub: "Depends on scope, layout changes, and finish level" }, { stat: "6–12 weeks", label: "Active Construction", sub: "Once materials are ordered and permits approved" }, { stat: "1 PM", label: "Your Point of Contact", sub: "Direct access — not a call center or shared inbox" }].map(item => (
        <div class="bg-fcd-cream border border-fcd-border rounded-lg p-8 text-center">
          <p class="font-heading text-4xl text-fcd-gold font-bold mb-2">{item.stat}</p>
          <p class="font-semibold text-fcd-navy mb-2">{item.label}</p>
          <p class="text-fcd-navy/60 text-sm">{item.sub}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="bg-fcd-cream py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <SectionLabel>FAQ</SectionLabel>
      <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-12">Kitchen Remodel Questions</h2>
      <div class="divide-y divide-fcd-border">
        {faqs.map(faq => (
          <div class="py-6">
            <button class="faq-btn w-full flex items-start justify-between gap-4 text-left group" aria-expanded="false">
              <h3 class="font-heading text-lg text-fcd-navy font-semibold group-hover:text-fcd-gold transition-colors pr-4">{faq.q}</h3>
              <svg class="faq-icon w-5 h-5 text-fcd-gold flex-shrink-0 mt-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer hidden mt-4"><p class="text-fcd-navy/75 leading-relaxed">{faq.a}</p></div>
          </div>
        ))}
      </div>
    </div>
  </section>
  <script is:inline>
    document.querySelectorAll('.faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.nextElementSibling; var icon = btn.querySelector('.faq-icon'); var isOpen = !answer.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.add('hidden'); });
        document.querySelectorAll('.faq-icon').forEach(function(ic) { ic.style.transform = ''; });
        document.querySelectorAll('.faq-btn').forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
        if (!isOpen) { answer.classList.remove('hidden'); icon.style.transform = 'rotate(180deg)'; btn.setAttribute('aria-expanded', 'true'); }
      });
    });
  </script>
  <section class="bg-fcd-navy py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <h2 class="font-heading text-3xl lg:text-5xl text-white font-bold tracking-tight mb-6">Ready to Transform Your Kitchen?</h2>
      <p class="text-white/70 text-lg max-w-2xl mx-auto mb-10">Tell us what you have in mind. We will give you a realistic budget and timeline — no pressure, no inflated quotes.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-10 py-5 hover:bg-fcd-gold-lt transition-colors duration-200">Get Free Kitchen Quote &rarr;</a>
        <a href="tel:7149279777" class="inline-flex items-center justify-center gap-2 border border-white/30 text-white font-semibold text-sm tracking-widest2 uppercase px-10 py-5 hover:border-fcd-gold hover:text-fcd-gold transition-colors duration-200">Call (714) 927-9777</a>
      </div>
      <p class="mt-8 text-white/40 text-sm">CA Lic. #1127416 &middot; Serving Orange County, CA</p>
    </div>
  </section>
</BaseLayout>
