---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionLabel from '../../components/SectionLabel.astro';

const faqs = [
  {
    q: "How much does an ADU cost in Orange County?",
    a: "Most ADU projects in Orange County range from $150,000 to $350,000 depending on size, type, and finish level. A garage conversion typically starts around $120,000–$180,000. A detached ADU of 600–800 sq ft usually runs $200,000–$280,000. We provide a fixed-price proposal after a site visit so you know exactly what you're committing to."
  },
  {
    q: "How long does it take to build an ADU in Orange County?",
    a: "From our first site visit to handing you keys, plan on 8–14 months total. Permit approval alone takes 3–6 months depending on the city and complexity. Once permits are issued, active construction runs 4–6 months. We track permit status for you and keep you updated throughout — no chasing required."
  },
  {
    q: "Do you handle the ADU permit process?",
    a: "Yes — completely. We prepare and submit all permit documents, coordinate with your city's building department, respond to plan check corrections, and schedule all inspections. You never have to step inside a permit office. This is included in every ADU project we take on."
  },
  {
    q: "Can I convert my garage into an ADU?",
    a: "In most Orange County cities, yes. Garage conversions are typically the most cost-effective ADU option since the structure already exists. We assess the foundation, existing electrical and plumbing, and structural walls to determine what's needed. Most garage conversions qualify as a JADU (Junior ADU) up to 500 sq ft or a standard ADU depending on the space."
  },
  {
    q: "What cities in Orange County do you build ADUs in?",
    a: "We build ADUs throughout Orange County including Garden Grove, Anaheim, Santa Ana, Huntington Beach, Irvine, Fullerton, Orange, Westminster, Fountain Valley, Costa Mesa, and surrounding cities. Each city has slightly different requirements — we know them all."
  },
  {
    q: "What is the difference between an ADU, JADU, and SB9 unit?",
    a: "An ADU (Accessory Dwelling Unit) is a fully independent unit with its own kitchen, bathroom, and entrance, up to 1,200 sq ft. A JADU (Junior ADU) is converted from existing space like a garage and is limited to 500 sq ft. An SB9 unit is created by splitting your lot or adding a second primary dwelling on an eligible single-family lot. We handle all three."
  },
  {
    q: "Will an ADU increase my property taxes?",
    a: "Yes, but only the value of the new ADU is reassessed — not your entire property. Your existing home's assessed value stays the same. The added tax is typically far less than the rental income the ADU generates."
  },
  {
    q: "Can I rent out my ADU immediately after it is built?",
    a: "Yes. Once we obtain your Certificate of Occupancy, the unit is legal to rent. Many of our clients cover their entire mortgage payment with ADU rental income."
  },
  {
    q: "Do I need to hire a separate architect for my ADU?",
    a: "Not necessarily. For standard ADU packages, we coordinate design and structural engineering in-house. If your project requires a fully custom design, we can refer you to architects we have worked with or work from plans you already have."
  },
  {
    q: "What is included in FCD's ADU package?",
    a: "Everything from site assessment and design coordination to permit submittal, full construction, city inspections, and final Certificate of Occupancy. Included: foundation, framing, roofing, electrical, plumbing, HVAC rough-in, insulation, drywall, flooring, cabinetry, fixtures, and exterior finish."
  },
];

const cities = [
  "Garden Grove", "Anaheim", "Santa Ana", "Huntington Beach",
  "Irvine", "Fullerton", "Orange", "Westminster",
  "Fountain Valley", "Costa Mesa", "Tustin", "Buena Park"
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "ADU Construction Orange County",
  "description": "Licensed ADU contractor serving Orange County, CA. Detached ADUs, garage conversions, JADUs, and SB9 units. Permits handled, design coordinated, full construction.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Future Construction & Design INC",
    "url": "https://www.fcdteam.com",
    "telephone": "(714) 927-9777",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "12122 Brookhurst St",
      "addressLocality": "Garden Grove",
      "addressRegion": "CA",
      "postalCode": "92840",
      "addressCountry": "US"
    },
    "license": "CA Lic. #1127416"
  },
  "serviceType": "ADU Construction",
  "areaServed": "Orange County, CA"
};
---

<BaseLayout
  title="ADU Contractor Orange County | Future Construction & Design"
  description="Licensed ADU contractor in Orange County, CA. Detached ADUs, garage conversions, JADUs, and SB9 units. We handle permits, design, and full construction. CA Lic. #1127416."
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="relative flex items-center" style="min-height: 55vh;">
    <div class="absolute inset-0 overflow-hidden">
      <img src="/images/projects/adu-1.jpg" alt="ADU construction Orange County" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(0,37,62,0.88) 50%, rgba(0,37,62,0.4));"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-20 w-full">
      <SectionLabel>ADU Construction · Orange County</SectionLabel>
      <h1 class="font-heading font-bold tracking-tight text-white text-4xl lg:text-6xl leading-[1.05] max-w-3xl mt-4">
        ADU Contractor Orange County
      </h1>
      <p class="mt-6 text-base lg:text-lg text-white/80 leading-relaxed max-w-2xl">
        We build detached ADUs, garage conversions, JADUs, and SB9 units across Orange County.
        Permits handled. Design coordinated. Keys delivered. CA Lic. #1127416.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4">
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:bg-fcd-gold-lt transition-colors duration-200">
          Get a Free ADU Quote &rarr;
        </a>
        <a href="tel:7149279777" class="inline-flex items-center justify-center gap-2 border border-white/40 text-white font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:border-fcd-gold hover:text-fcd-gold transition-colors duration-200">
          (714) 927-9777
        </a>
      </div>
      <div class="mt-8 flex flex-wrap gap-6 text-sm text-white/70">
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Permits Included</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>Fixed-Price Proposals</span>
        <span class="flex items-center gap-2"><svg class="w-4 h-4 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>CA Licensed &amp; Insured</span>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="bg-fcd-cream py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <SectionLabel>Why Build an ADU</SectionLabel>
          <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-6">
            The Highest-ROI Move You Can Make on Your Orange County Property
          </h2>
          <p class="text-fcd-navy/80 leading-relaxed mb-5">
            Orange County homeowners are sitting on some of the most valuable land in California.
            An ADU lets you put that land to work — generating rental income, housing family members,
            or adding significant equity without buying a new property.
          </p>
          <p class="text-fcd-navy/80 leading-relaxed mb-5">
            The average detached ADU in Orange County adds $180,000–$300,000 in property value
            and generates $1,800–$2,800/month in rental income. That is a mortgage offset most
            homeowners did not know was sitting in their backyard.
          </p>
          <p class="text-fcd-navy/80 leading-relaxed">
            But only if it is built right, permitted clean, and delivered on time. We have handled
            the full ADU process — design coordination, permit submittal, construction, and Certificate
            of Occupancy — so you can focus on what to do with the income, not the headache.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-lg overflow-hidden aspect-[4/3]">
            <img src="/images/projects/adu-2.jpg" alt="Detached ADU Orange County" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-lg overflow-hidden aspect-[4/3] mt-8">
            <img src="/images/projects/adu-3.jpg" alt="ADU garage conversion Orange County" loading="lazy" class="w-full h-full object-cover" />
          </div>
          <div class="rounded-lg overflow-hidden aspect-[4/3] col-span-2">
            <img src="/images/projects/adu-4.jpg" alt="ADU completed Orange County" loading="lazy" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ADU TYPES -->
  <section class="bg-fcd-dark py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <SectionLabel>What We Build</SectionLabel>
      <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-4 max-w-2xl">
        Every Type of ADU in Orange County — Done Right
      </h2>
      <p class="text-fcd-navy/70 max-w-2xl mb-14">
        Every property is different. We assess your lot, your goals, and your budget to recommend
        the right ADU type before we quote a single dollar.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-fcd-cream border border-fcd-border rounded-lg p-8 hover:border-fcd-gold transition-colors">
          <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-full border border-fcd-gold/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l9-9 9 9M5 10v11h14V10"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wider uppercase text-fcd-gold bg-fcd-gold/10 px-3 py-1 rounded-full">Most Popular</span>
          </div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Detached ADU</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">A fully independent structure in your backyard, separate from your main home. Maximum privacy for tenants or family. Typically 400–1,200 sq ft. Best long-term value addition to your property.</p>
        </div>
        <div class="bg-fcd-cream border border-fcd-border rounded-lg p-8 hover:border-fcd-gold transition-colors">
          <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-full border border-fcd-gold/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4z"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wider uppercase text-fcd-gold bg-fcd-gold/10 px-3 py-1 rounded-full">Most Cost-Effective</span>
          </div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Garage Conversion</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">Turn an unused garage into a permitted, rentable unit. Most cost-effective ADU option — the structure already exists. Works as a JADU (up to 500 sq ft) or full ADU depending on garage size.</p>
        </div>
        <div class="bg-fcd-cream border border-fcd-border rounded-lg p-8 hover:border-fcd-gold transition-colors">
          <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-full border border-fcd-gold/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wider uppercase text-fcd-gold bg-fcd-gold/10 px-3 py-1 rounded-full">Best for Families</span>
          </div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Attached ADU</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">Built as an addition to your existing home, sharing one or more walls. More affordable than detached and gives you added square footage with a fully independent unit. Common for multigenerational living.</p>
        </div>
        <div class="bg-fcd-cream border border-fcd-border rounded-lg p-8 hover:border-fcd-gold transition-colors">
          <div class="flex items-start justify-between mb-4">
            <div class="w-11 h-11 rounded-full border border-fcd-gold/40 flex items-center justify-center">
              <svg class="w-5 h-5 text-fcd-gold" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
            </div>
            <span class="text-xs font-semibold tracking-wider uppercase text-fcd-gold bg-fcd-gold/10 px-3 py-1 rounded-full">Easiest to Permit</span>
          </div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">JADU (Junior ADU)</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">Converted from existing space inside or attached to your home, up to 500 sq ft. Lowest permitting hurdles under California law. Great starting option for homeowners exploring rental income for the first time.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-fcd-cream py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <SectionLabel>Our Process</SectionLabel>
      <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-16 max-w-2xl">
        From Site Visit to Certificate of Occupancy — We Handle Everything
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
        <div>
          <div class="text-6xl font-heading font-bold text-fcd-gold/20 leading-none mb-4">01</div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Free Site Assessment</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">We visit your property, review zoning and setback requirements, and assess what ADU options make sense for your lot and goals. No charge, no obligation.</p>
        </div>
        <div>
          <div class="text-6xl font-heading font-bold text-fcd-gold/20 leading-none mb-4">02</div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Design &amp; Engineering</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">We coordinate architectural drawings and structural engineering. For standard packages, this is managed in-house. For custom builds, we work with your architect or refer one.</p>
        </div>
        <div>
          <div class="text-6xl font-heading font-bold text-fcd-gold/20 leading-none mb-4">03</div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Permit Submittal</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">We prepare and submit all permit documents to your city, respond to plan check corrections, and track status. Most cities take 3–6 months. We keep you updated throughout.</p>
        </div>
        <div>
          <div class="text-6xl font-heading font-bold text-fcd-gold/20 leading-none mb-4">04</div>
          <h3 class="font-heading text-xl text-fcd-navy font-semibold mb-3">Construction &amp; CO</h3>
          <p class="text-fcd-navy/70 text-sm leading-relaxed">Once permits are issued, active construction takes 4–6 months. We schedule all city inspections and deliver a Certificate of Occupancy — ready to rent from day one.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY FCD -->
  <section class="bg-fcd-dark py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <div>
        <SectionLabel>Why FCD</SectionLabel>
        <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-8">
          What Makes Us Different From Every Other ADU Contractor in Orange County
        </h2>
        <div class="space-y-6">
          <div class="flex gap-4">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <div>
              <p class="font-semibold text-fcd-navy">We do not disappear after the permit</p>
              <p class="text-fcd-navy/70 text-sm mt-1">Some contractors help you design and permit but hand off construction to subs you have never met. We build it ourselves, start to finish, with the same team.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <div>
              <p class="font-semibold text-fcd-navy">Fixed-price proposals — no surprises</p>
              <p class="text-fcd-navy/70 text-sm mt-1">We lock in price before we break ground. Change orders only happen if you change the scope, not because we estimated incorrectly.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <div>
              <p class="font-semibold text-fcd-navy">We know every OC city's permit process</p>
              <p class="text-fcd-navy/70 text-sm mt-1">Garden Grove, Irvine, Anaheim, Huntington Beach — each city has different timelines, fees, and requirements. We have been through all of them.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <div>
              <p class="font-semibold text-fcd-navy">Daily updates. Always reachable.</p>
              <p class="text-fcd-navy/70 text-sm mt-1">You get photo logs every day your project is active and direct access to your Project Manager — not a call center, not a shared inbox.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="bg-fcd-cream border border-fcd-border rounded-lg p-10">
        <p class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold mb-6">By the Numbers</p>
        <div class="grid grid-cols-2 gap-8">
          <div>
            <p class="font-heading text-3xl text-fcd-gold font-bold">$150K–$350K</p>
            <p class="text-fcd-navy/60 text-sm mt-1">Typical ADU Range</p>
          </div>
          <div>
            <p class="font-heading text-3xl text-fcd-gold font-bold">8–14 mo</p>
            <p class="text-fcd-navy/60 text-sm mt-1">Site Visit to Keys</p>
          </div>
          <div>
            <p class="font-heading text-3xl text-fcd-gold font-bold">3–6 mo</p>
            <p class="text-fcd-navy/60 text-sm mt-1">Typical Permit Window</p>
          </div>
          <div>
            <p class="font-heading text-3xl text-fcd-gold font-bold">$1,800+</p>
            <p class="text-fcd-navy/60 text-sm mt-1">Est. Monthly Rental Income</p>
          </div>
        </div>
        <div class="border-t border-fcd-border mt-10 pt-8">
          <p class="text-fcd-navy/80 text-sm leading-relaxed mb-6">
            Ready to find out what is possible on your property? We will assess your lot,
            run the numbers, and give you an honest picture — no pressure, no sales pitch.
          </p>
          <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:bg-fcd-gold-lt transition-colors duration-200 w-full">
            Get Free ADU Assessment &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="bg-fcd-cream py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-12">
      <SectionLabel>Service Area</SectionLabel>
      <h2 class="font-heading text-2xl text-fcd-navy font-semibold mt-4 mb-8">
        ADU Contractor Serving All of Orange County
      </h2>
      <div class="flex flex-wrap gap-3">
        {cities.map(city => (
          <span class="bg-fcd-dark border border-fcd-border text-fcd-navy text-sm font-medium px-4 py-2 rounded-full">{city}, CA</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-fcd-dark py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-6 lg:px-12">
      <SectionLabel>FAQ</SectionLabel>
      <h2 class="font-heading text-3xl lg:text-4xl text-fcd-navy font-semibold mt-4 mb-12">
        ADU Questions — Answered Honestly
      </h2>
      <div class="divide-y divide-fcd-border">
        {faqs.map((faq, i) => (
          <div class="py-6">
            <button class="faq-btn w-full flex items-start justify-between gap-4 text-left group" aria-expanded="false">
              <h3 class="font-heading text-lg text-fcd-navy font-semibold group-hover:text-fcd-gold transition-colors pr-4">{faq.q}</h3>
              <svg class="faq-icon w-5 h-5 text-fcd-gold flex-shrink-0 mt-1 transition-transform duration-200" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="faq-answer hidden mt-4">
              <p class="text-fcd-navy/75 leading-relaxed">{faq.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script is:inline>
    document.querySelectorAll('.faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var answer = btn.nextElementSibling;
        var icon = btn.querySelector('.faq-icon');
        var isOpen = !answer.classList.contains('hidden');
        document.querySelectorAll('.faq-answer').forEach(function(a) { a.classList.add('hidden'); });
        document.querySelectorAll('.faq-icon').forEach(function(ic) { ic.style.transform = ''; });
        document.querySelectorAll('.faq-btn').forEach(function(b) { b.setAttribute('aria-expanded', 'false'); });
        if (!isOpen) {
          answer.classList.remove('hidden');
          icon.style.transform = 'rotate(180deg)';
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>

