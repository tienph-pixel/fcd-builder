---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionLabel from '../components/SectionLabel.astro';

const services = [
  {
    title: 'Multifamily Construction',
    label: 'Multifamily',
    image: 'https://images.unsplash.com/photo-1545324418-cc1a3fa10c00?w=1200&q=80',
    description: 'We build duplexes, triplexes, and 4–20 unit apartment buildings for developers and investors who need a contractor that runs a tight project. From dirt to certificate of occupancy — we handle it. Mixed-use ground-floor commercial? Done. Investor reporting and schedule transparency at every milestone — built in.',
    bullets: [
      'Duplexes, triplexes, 4–20 unit apartment buildings',
      'Mixed-use residential / commercial',
      'Full-cycle: permits, framing, MEP, finishes',
      'Investor reporting and schedule transparency',
    ],
  },
  {
    title: 'Custom Home Builds',
    label: 'Custom Homes',
    image: '/images/projects/custom-home-1.jpg',
    description: 'Building a custom home is the biggest project most families ever take on. We make it feel like a real partnership — not a transaction. Whether you bring us a finished set of plans or want a true design-build experience, we coordinate your architect, value-engineer the budget, and deliver a finished home you actually want to live in.',
    bullets: [
      'Ground-up construction from plans or design-build',
      'Architect coordination or referral',
      'Budget development and value engineering',
      'High-end finishes and custom millwork available',
    ],
  },
  {
    title: 'ADU Construction',
    label: 'ADU',
    image: '/images/projects/adu-1.jpg',
    description: 'ADUs are one of the highest-ROI moves you can make on your property — but only if they\'re built right and permitted clean. We handle the entire process: design coordination, structural engineering referrals, full permit submittal, and construction. Detached, attached, or garage conversion — we deliver the keys.',
    bullets: [
      'Detached, attached, or garage conversion',
      'Full permit processing included',
      'Design coordination and structural engineering referrals',
      'Standard ADU packages starting at fixed price',
    ],
  },
  {
    title: 'Remodels & Renovations',
    label: 'Remodels',
    image: '/images/projects/remodel-1.jpg',
    description: 'A remodel done right transforms how your home feels — and how it functions. Done wrong, it\'s a months-long nightmare. We treat your home like ours: clean job sites, daily updates, respectful crews, and a finish that actually matches what we promised on day one. Kitchens, bathrooms, additions, structural — all coordinated in-house.',
    bullets: [
      'Kitchen and bathroom remodels',
      'Whole-home renovations',
      'Room additions and structural changes',
      'Structural, electrical, plumbing — all in-house coordination',
    ],
  },
];
---
<BaseLayout
  title="Our Services — Custom Homes, ADU, Remodels"
  description="Full-service construction: multifamily, custom homes, ADUs, and remodels."
>

  <!-- HERO -->
  <section class="relative flex items-center" style="min-height: 60vh;">
    <div class="absolute inset-0 bg-fcd-dark"></div>
    <div class="absolute inset-0" style="background: radial-gradient(ellipse at center, rgba(201,168,76,0.08), rgba(10,10,15,0));"></div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-12 py-16 w-full">
      <SectionLabel>Our Services</SectionLabel>
      <h1 class="font-heading font-bold tracking-tight text-fcd-navy text-5xl lg:text-7xl leading-[1.05] max-w-4xl">
        Everything You Need. One Builder You Can Trust.
      </h1>
      <p class="mt-8 text-base lg:text-lg text-fcd-navy/80 leading-relaxed max-w-2xl">
        Whether it's a 12-unit apartment building or a single-bath remodel — we run the same playbook. Same standard. Same accountability. Same care.
      </p>
    </div>
  </section>

  <!-- SERVICE SECTIONS -->
  {services.map((s, i) => (
    <section class={`py-24 lg:py-32 ${i % 2 === 0 ? 'bg-fcd-cream' : 'bg-fcd-dark'}`}>
      <div class="max-w-7xl mx-auto px-6 lg:px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class={i % 2 === 0 ? 'lg:order-1' : 'lg:order-2'}>
          <SectionLabel>{s.label}</SectionLabel>
          <h2 class="font-heading text-4xl text-fcd-navy font-semibold mb-6">{s.title}</h2>
          <p class="text-base lg:text-lg text-fcd-navy/80 leading-relaxed mb-8">{s.description}</p>
          <ul class="space-y-3">
            {s.bullets.map(b => (
              <li class="flex items-start gap-3">
                <svg class="w-5 h-5 text-fcd-gold flex-shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                <span class="text-fcd-navy/90">{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class={`rounded-lg overflow-hidden aspect-[4/3] ${i % 2 === 0 ? 'lg:order-2' : 'lg:order-1'}`}>
          <img src={s.image} alt={s.title} loading="lazy" class="w-full h-full object-cover" />
        </div>
      </div>
    </section>
  ))}

  <!-- CTA -->
  <section class="bg-fcd-cream py-24 lg:py-32 border-t border-fcd-border">
    <div class="max-w-4xl mx-auto px-6 lg:px-12 text-center">
      <h2 class="font-heading text-4xl lg:text-5xl text-fcd-navy font-bold tracking-tight">Tell Us What You're Building.</h2>
      <p class="mt-6 text-base lg:text-lg text-fcd-navy/80 max-w-2xl mx-auto">A 10-minute call is enough to give you a real ballpark. Don't waste your time chasing builders who won't pick up.</p>
      <div class="mt-10">
        <a href="/contact" class="inline-flex items-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-10 py-5 hover:bg-fcd-gold-lt transition-colors duration-200">Start My Project →</a>
      </div>
    </div>
  </section>

</BaseLayout>
