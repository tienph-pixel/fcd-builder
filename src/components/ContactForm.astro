---
---
<form
  action="https://formspree.io/f/mbdwdbkn"
  method="POST"
  class="space-y-5"
>
  <input type="hidden" name="_subject" value="New Project Inquiry — FCD Builder" />
  <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off" />
  <input type="hidden" name="_next" value="/thank-you" />

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <label class="block">
      <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">Full Name *</span>
      <input type="text" name="name" required class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy placeholder-fcd-muted focus:outline-none focus:border-fcd-gold transition-colors" />
    </label>

    <label class="block">
      <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">Phone Number *</span>
      <input type="tel" name="phone" required class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy placeholder-fcd-muted focus:outline-none focus:border-fcd-gold transition-colors" />
    </label>
  </div>

  <label class="block">
    <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">Email Address *</span>
    <input type="email" name="email" required class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy placeholder-fcd-muted focus:outline-none focus:border-fcd-gold transition-colors" />
  </label>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    <label class="block">
      <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">Project Type *</span>
      <select name="project_type" required class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy focus:outline-none focus:border-fcd-gold transition-colors">
        <option value="">Select project type…</option>
        <option>ADU / JADU / SB9</option>
        <option>Custom Home Build</option>
        <option>Whole-Home Renovation</option>
        <option>Kitchen / Bathroom Remodel</option>
      </select>
    </label>

    <label class="block">
      <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">Property City *</span>
      <select name="city" required class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy focus:outline-none focus:border-fcd-gold transition-colors">
        <option value="">Select your city…</option>
        <optgroup label="Orange County">
          <option>Anaheim</option>
          <option>Brea</option>
          <option>Buena Park</option>
          <option>Costa Mesa</option>
          <option>Cypress</option>
          <option>Dana Point</option>
          <option>Fountain Valley</option>
          <option>Fullerton</option>
          <option>Garden Grove</option>
          <option>Huntington Beach</option>
          <option>Irvine</option>
          <option>La Habra</option>
          <option>La Palma</option>
          <option>Laguna Beach</option>
          <option>Laguna Hills</option>
          <option>Laguna Niguel</option>
          <option>Lake Forest</option>
          <option>Los Alamitos</option>
          <option>Mission Viejo</option>
          <option>Newport Beach</option>
          <option>Orange</option>
          <option>Placentia</option>
          <option>Rancho Santa Margarita</option>
          <option>San Clemente</option>
          <option>San Juan Capistrano</option>
          <option>Santa Ana</option>
          <option>Seal Beach</option>
          <option>Stanton</option>
          <option>Tustin</option>
          <option>Villa Park</option>
          <option>Westminster</option>
          <option>Yorba Linda</option>
        </optgroup>
        <optgroup label="Los Angeles">
          <option>Beverly Hills</option>
          <option>Burbank</option>
          <option>Carson</option>
          <option>Compton</option>
          <option>Culver City</option>
          <option>Downey</option>
          <option>East Los Angeles</option>
          <option>El Monte</option>
          <option>Glendale</option>
          <option>Hawthorne</option>
          <option>Inglewood</option>
          <option>Long Beach</option>
          <option>Los Angeles</option>
          <option>Norwalk</option>
          <option>Pasadena</option>
          <option>Pomona</option>
          <option>Santa Clarita</option>
          <option>Santa Monica</option>
          <option>Torrance</option>
          <option>West Covina</option>
          <option>West Hollywood</option>
          <option>Whittier</option>
        </optgroup>
      </select>
    </label>
  </div>

  <label class="block">
    <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">When are you hoping to start?</span>
    <select name="timeline" class="mt-2 w-full bg-fcd-dark border border-fcd-border rounded px-4 py-3 text-fcd-navy focus:outline-none focus:border-fcd-gold transition-colors">
      <option value="">Select timeline…</option>
      <option>ASAP</option>
      <option>1–3 Months</option>
      <option>3–6 Months</option>
      <option>6–12 Months</option>
      <option>Just Exploring</option>
    </select>
  </label>

  <label class="block">
    <span class="text-xs font-semibold tracking-widest2 uppercase text-fcd-gold">How Ready Are You to Start?</span>
    <div class="mt-3 flex items-center gap-4">
      <input type="range" name="readiness" min="0" max="100" value="50" class="flex-1 accent-fcd-gold" />
      <span id="readiness-value" class="font-heading text-lg text-fcd-gold font-semibold w-24 text-right tabular-nums">50% Ready</span>
    </div>
  </label>
  <script is:inline>
    (function() {
      const range = document.querySelector('input[name="readiness"]');
      const out = document.getElementById('readiness-value');
      if (!range || !out) return;
      function update() { out.textContent = range.value + '% Ready'; }
      range.addEventListener('input', update);
      update();
    })();
  </script>

  <!-- Trust bullets -->
  <ul class="space-y-2 pt-2">
    <li class="flex items-start gap-2 text-sm text-fcd-navy/90">
      <svg class="w-4 h-4 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span>No commitment required — just honest answers</span>
    </li>
    <li class="flex items-start gap-2 text-sm text-fcd-navy/90">
      <svg class="w-4 h-4 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span>CA Lic. #1127416 — Licensed &amp; Insured</span>
    </li>
    <li class="flex items-start gap-2 text-sm text-fcd-navy/90">
      <svg class="w-4 h-4 text-fcd-gold flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
      <span>We respond within 1 business day</span>
    </li>
  </ul>

  <button
    type="submit"
    class="inline-flex items-center gap-2 bg-fcd-gold text-fcd-black font-semibold text-sm tracking-widest2 uppercase px-8 py-4 hover:bg-fcd-gold-lt transition-colors duration-200 mt-2"
  >Get My Free Ballpark Estimate →</button>
</form>
